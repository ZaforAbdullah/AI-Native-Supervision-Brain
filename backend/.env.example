SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Local Supabase Postgres (run `supabase start`)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# AI provider — "lm_studio" for local dev, "gemini" for production, leave blank to disable
AI_PROVIDER=lm_studio

# LM Studio (local development)
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_STUDIO_MODEL=local-model

# Google Gemini (production)
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash

# Keeps Gemini calls under the API quota (free tier is 15/min — default leaves headroom).
# Doesn't apply to LM Studio, which isn't quota-limited, just hardware-limited.
AI_RATE_LIMIT_PER_MINUTE=10
# Per-request timeout in seconds, applies to both providers.
AI_REQUEST_TIMEOUT_SECONDS=60

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@supervision-brain.local

ANALYSIS_SCHEDULE_HOUR=2
ANALYSIS_SCHEDULE_MINUTE=0

CORS_ORIGINS=http://localhost:3000
